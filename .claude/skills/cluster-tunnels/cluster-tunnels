#!/usr/bin/env zsh
#
# cluster-tunnels — open laptop-relayed SSH tunnels so a "source" cluster
# can reach destination clusters it cannot route to directly, and (optionally)
# reach the laptop itself. The laptop is the pivot:
#
#     laptop  --(-L)-->  dest:22                       (one per destination)
#     source  --(-R)-->  laptop  --(-L)-->  dest:22    (reach dest from source)
#     source  --(-R)-->  laptop:22                     (reach the LAPTOP from source, host "mac")
#
# Usage:
#   cluster-tunnels [up|down|status|config]
#     up      open all tunnels (default), print the source-side ssh config, and
#             (on macOS, if MANAGE_MAC_SSHD) enable Remote Login + ensure your
#             account is in the SSH access group (self-heals the macOS reset)
#     down    close all tunnels; (on macOS, if MANAGE_MAC_SSHD) disable Remote Login
#     status  show tunnel state, and (on macOS) whether the Mac's sshd is serving
#     config  just print the source-side ~/.ssh/config block
#
set -euo pipefail

# ============================ Configuration ============================

# The cluster you want to initiate connections FROM.
SOURCE_HOST="rno"

# Your username on the destination clusters (used only in the printed config).
DEST_USER="vincent.pfister"

# Destinations reachable from the laptop.
# Each entry: "<ssh-host>  <laptop_local_port>  <source_remote_port>"
#   laptop_local_port  : port on the laptop for the -L forward to <ssh-host>:22
#   source_remote_port : port on SOURCE_HOST that maps back to <ssh-host>
DESTINATIONS=(
  "ala0  2200  12222"
  "bar0  2201  12223"
)

# Expose the laptop's OWN sshd back to the source, so the source can
# `ssh $MAC_HOST` into the laptop. This is just the reverse leg pointed at
# laptop:22 instead of at a destination.
# Leave EXPOSE_LAPTOP_PORT empty ("") to disable.
EXPOSE_LAPTOP_PORT="12224"     # port on SOURCE_HOST that maps back to laptop:22
MAC_HOST="mac"                 # ssh alias created on the source
MAC_USER="vincent.pfister"     # your username on the Mac (must match `whoami`, case-sensitive)

# When EXPOSE_LAPTOP_PORT is set AND we're running on macOS (laptop == the Mac),
# also manage the Mac's own Remote Login (sshd) as part of up/down/status:
#   up     -> enable Remote Login + ensure $MAC_USER is in the com.apple.access_ssh
#             group (this self-heals the macOS access-list that resets on toggle/sleep)
#   down   -> disable Remote Login
#   status -> report whether sshd serves on :22 and whether access is granted
# Needs sudo; `systemsetup -setremotelogin` also needs your TERMINAL to have Full
# Disk Access. Set to "" to leave the Mac's sshd completely untouched.
MANAGE_MAC_SSHD="yes"

# Dedicated control sockets for this script (kept separate from your
# interactive masters so they can be managed independently).
SOCKET_DIR="$HOME/.ssh/sockets/tunnels"

# Options shared by every tunnel master connection.
SSH_COMMON=(
  -o ExitOnForwardFailure=yes      # fail loudly if a forward can't bind
  -o ServerAliveInterval=30
  -o ServerAliveCountMax=3
  -o ControlMaster=yes
  -o ControlPersist=yes            # stay up until `down`; survives the shell
)

# =======================================================================

mkdir -p "$SOCKET_DIR"; chmod 700 "$SOCKET_DIR"

_sock()  { print -r -- "$SOCKET_DIR/$1"; }

_is_up() {  # tag host
  ssh -O check -o ControlPath="$(_sock "$1")" "$2" >/dev/null 2>&1
}

_stop()  {  # tag host
  if _is_up "$1" "$2"; then
    ssh -O exit -o ControlPath="$(_sock "$1")" "$2" >/dev/null 2>&1 || true
    print -r -- "  closed:    $1 ($2)"
  fi
  rm -f "$(_sock "$1")"
}

# ---- macOS Remote Login (the "mac" host's sshd) management ----
_is_macos()      { [[ "$(uname)" == "Darwin" ]]; }
_manage_mac()    { _is_macos && [[ -n "$EXPOSE_LAPTOP_PORT" && -n "$MANAGE_MAC_SSHD" ]]; }
_mac_sshd_live() { bash -c 'exec 3<>/dev/tcp/127.0.0.1/22' 2>/dev/null; }  # sudo-free
_mac_access_ok() { dseditgroup -o checkmember -m "$MAC_USER" com.apple.access_ssh >/dev/null 2>&1; }

_mac_sshd_up() {
  _manage_mac || return 0
  # nothing to do if sshd is already serving and access resolves
  if _mac_sshd_live && _mac_access_ok; then
    print -r -- "  mac sshd:  already serving on :22, $MAC_USER allowed"
    return 0
  fi
  # We need sudo. Authenticate VISIBLY first — otherwise the suppressed sudo
  # calls below hide the password prompt and the script just looks hung. Note:
  # sudo Touch ID does NOT work inside tmux without pam_reattach, so this may ask
  # for your password instead of a fingerprint.
  print -r -- "  mac sshd:  need sudo to enable Remote Login / SSH access..."
  if ! sudo -v; then
    print -r -- "  ! sudo not authorized — skipping mac sshd setup (run 'sudo -v' first; for Touch ID in tmux install pam_reattach)"
    return 0
  fi
  _mac_sshd_live || sudo systemsetup -f -setremotelogin on >/dev/null 2>&1 \
    || print -r -- "  ! couldn't enable Remote Login — grant your TERMINAL Full Disk Access, or toggle it in System Settings > Sharing"
  # best-effort: keep your account in the SSH access group (may be a no-op if you
  # decoupled sshd from the SACL via /etc/pam.d/sshd).
  if ! _mac_access_ok; then
    sudo dseditgroup -o create com.apple.access_ssh >/dev/null 2>&1 || true
    sudo dseditgroup -o edit -a "$MAC_USER" -t user com.apple.access_ssh >/dev/null 2>&1 || true
    sudo dsmemberutil flushcache >/dev/null 2>&1 || true
  fi
}

_mac_sshd_down() {
  _manage_mac || return 0
  print -r -- "  mac sshd:  need sudo to disable Remote Login..."
  if ! sudo -v; then
    print -r -- "  ! sudo not authorized — leaving Remote Login as-is (run 'sudo -v' first)"
    return 0
  fi
  sudo systemsetup -f -setremotelogin off >/dev/null 2>&1 \
    || print -r -- "  ! couldn't disable Remote Login (needs Full Disk Access)"
}

_mac_sshd_status() {
  _is_macos || return 0
  [[ -n "$EXPOSE_LAPTOP_PORT" ]] || return 0
  if _mac_sshd_live; then
    print -r -- "  UP    mac sshd (:22 serving)"
  else
    print -r -- "  DOWN  mac sshd (:22 not serving — Remote Login off?)"
  fi
  if _mac_access_ok; then
    print -r -- "  OK    mac access: $MAC_USER in com.apple.access_ssh"
  else
    print -r -- "  WARN  mac access: $MAC_USER not in com.apple.access_ssh (All-users mode or excluded)"
  fi
}

up() {
  # 0) (macOS) make sure the laptop's own sshd is reachable as "mac"
  _mac_sshd_up

  # 1) local forwards: laptop -> each destination
  for entry in $DESTINATIONS; do
    local parts=(${=entry}); local name=$parts[1] lport=$parts[2]
    local tag="L-$name"
    if _is_up "$tag" "$name"; then
      print -r -- "  already up: $tag"
    else
      print -r -- "  opening:   laptop:$lport -> $name:22   (Touch ID may prompt)"
      ssh -f -N $SSH_COMMON -o ControlPath="$(_sock "$tag")" \
        -L "127.0.0.1:${lport}:localhost:22" "$name"
    fi
  done

  # 2) one reverse connection to SOURCE carrying every -R forward
  local rflags=()
  for entry in $DESTINATIONS; do
    local parts=(${=entry}); local lport=$parts[2] rport=$parts[3]
    rflags+=(-R "127.0.0.1:${rport}:127.0.0.1:${lport}")
  done
  # optional: expose the laptop's own sshd back to the source as host "mac"
  if [[ -n "$EXPOSE_LAPTOP_PORT" ]]; then
    rflags+=(-R "127.0.0.1:${EXPOSE_LAPTOP_PORT}:127.0.0.1:22")
  fi
  local tag="R-$SOURCE_HOST"
  if _is_up "$tag" "$SOURCE_HOST"; then
    print -r -- "  already up: $tag"
  else
    print -r -- "  opening:   $SOURCE_HOST reverse forwards   (Touch ID may prompt)"
    ssh -f -N $SSH_COMMON -o ControlPath="$(_sock "$tag")" $rflags "$SOURCE_HOST"
  fi
}

down() {
  _stop "R-$SOURCE_HOST" "$SOURCE_HOST"
  for entry in $DESTINATIONS; do
    local parts=(${=entry}); _stop "L-$parts[1]" "$parts[1]"
  done
  # (macOS) also stop the laptop's Remote Login
  _mac_sshd_down
}

status() {
  if _is_up "R-$SOURCE_HOST" "$SOURCE_HOST"; then
    print -r -- "  UP    R-$SOURCE_HOST${EXPOSE_LAPTOP_PORT:+  (carries dests + $MAC_HOST)}"
  else
    print -r -- "  DOWN  R-$SOURCE_HOST"
  fi
  for entry in $DESTINATIONS; do
    local parts=(${=entry}); local name=$parts[1]
    if _is_up "L-$name" "$name"; then
      print -r -- "  UP    L-$name"
    else
      print -r -- "  DOWN  L-$name"
    fi
  done
  # (macOS) report the mac host's own sshd + access state
  _mac_sshd_status
}

_print_host_block() {  # host port user alias
  print -r -- ""
  print -r -- "Host $1"
  print -r -- "    HostName 127.0.0.1"
  print -r -- "    Port $2"
  print -r -- "    User $3"
  print -r -- "    HostKeyAlias $4"
  print -r -- "    StrictHostKeyChecking accept-new"
  print -r -- "    ControlMaster auto"
  print -r -- "    ControlPath ~/.ssh/sockets/%C"
  print -r -- "    ControlPersist 60m"
}

print_config() {
  print -r -- "# ===== add to ~/.ssh/config on $SOURCE_HOST ====="
  print -r -- "# one-time setup ON $SOURCE_HOST:"
  print -r -- "#   1) mkdir -p ~/.ssh/sockets && chmod 700 ~/.ssh/sockets   (for ControlPath)"
  print -r -- "#   2) log in to $SOURCE_HOST with agent forwarding (ssh -A $SOURCE_HOST) so your"
  print -r -- "#      forwarded key authenticates onward to the destinations / the Mac"
  for entry in $DESTINATIONS; do
    local parts=(${=entry}); local name=$parts[1] rport=$parts[3]
    _print_host_block "$name" "$rport" "$DEST_USER" "$name-via-tunnel"
  done
  if [[ -n "$EXPOSE_LAPTOP_PORT" ]]; then
    _print_host_block "$MAC_HOST" "$EXPOSE_LAPTOP_PORT" "$MAC_USER" "mac-via-tunnel"
    print -r -- "    # '$MAC_HOST' is your laptop. On the Mac: this script's 'up' enables Remote"
    print -r -- "    #   Login + adds $MAC_USER to com.apple.access_ssh; you still need your key in"
    print -r -- "    #   ~/.ssh/authorized_keys (append 'ssh-add -L' on the laptop)."
  fi
}

case "${1:-up}" in
  up)     up; print -r -- ""; print_config ;;
  down)   down ;;
  status) status ;;
  config) print_config ;;
  *)      print -r -- "usage: ${0:t} [up|down|status|config]" >&2; exit 2 ;;
esac
